<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>SleepyQuiz Arcane WebApp</title>

<link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@400;600;700;800&display=swap" rel="stylesheet">

<style>
* {
  box-sizing: border-box;
}

html, body {
  margin: 0;
  width: 100%;
  height: 100%;
  overflow: hidden;
  font-family: "Open Sans", Arial, sans-serif;
  background: #030712;
  color: #d8ecff;
}

body {
  background:
    radial-gradient(circle at center, rgba(65,160,255,0.18), transparent 38%),
    linear-gradient(135deg, #02040a, #071426, #02040a);
}

body::before {
  content: "";
  position: fixed;
  inset: 0;
  background-image: radial-gradient(circle, rgba(120,220,255,0.22) 1px, transparent 1px);
  background-size: 90px 90px;
  opacity: 0.35;
  animation: drift 26s linear infinite;
  pointer-events: none;
}

@keyframes drift {
  from { transform: translateY(0); }
  to { transform: translateY(90px); }
}

.app {
  width: 100vw;
  height: 100vh;
  padding: 42px;
  display: grid;
  grid-template-columns: 1fr 360px;
  gap: 28px;
}

.frame {
  position: fixed;
  inset: 24px;
  border: 2px solid rgba(85,201,255,0.35);
  border-radius: 18px;
  box-shadow:
    0 0 14px rgba(85,201,255,0.22),
    inset 0 0 18px rgba(85,201,255,0.10);
  pointer-events: none;
}

.viewer {
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 24px;
  min-width: 0;
}

.clock {
  text-align: center;
  text-shadow: 0 0 8px rgba(85,201,255,0.25);
}

.date {
  font-size: clamp(18px, 2vw, 28px);
  font-weight: 700;
  letter-spacing: 2px;
}

.time {
  font-size: clamp(38px, 5vw, 74px);
  font-weight: 800;
  letter-spacing: 2px;
}

.card {
  min-height: 310px;
  padding: 38px 44px;
  border-radius: 22px;
  background: rgba(5, 12, 26, 0.88);
  border: 1px solid rgba(85,201,255,0.36);
  box-shadow:
    0 0 18px rgba(85,201,255,0.16),
    inset 0 0 28px rgba(85,201,255,0.08);
}

.label {
  color: #55c9ff;
  font-size: 20px;
  font-weight: 800;
  letter-spacing: 2px;
  margin-bottom: 18px;
  text-shadow: 0 0 7px rgba(85,201,255,0.30);
}

.question {
  font-size: clamp(28px, 3.5vw, 58px);
  line-height: 1.42;
  font-weight: 700;
  letter-spacing: 0.5px;
}

.answer {
  display: none;
  margin-top: 26px;
  padding: 20px 24px;
  border-left: 4px solid #9cffbd;
  border-radius: 12px;
  background: rgba(20, 80, 45, 0.24);
  color: #e2ffe9;
  font-size: clamp(24px, 2.5vw, 42px);
  font-weight: 700;
  line-height: 1.35;
}

.timer-wrap {
  height: 18px;
  border-radius: 999px;
  overflow: hidden;
  background: rgba(3,7,14,0.9);
  border: 1px solid rgba(85,201,255,0.30);
}

.timer-bar {
  height: 100%;
  width: 100%;
  background: linear-gradient(90deg, rgba(85,201,255,0.35), rgba(85,201,255,1));
  box-shadow: 0 0 14px rgba(85,201,255,0.42);
  transition: width 0.3s linear;
}

.controls {
overflow-y: auto;
max-height: 90vh;  align-self: center;
  padding: 20px;
  border-radius: 20px;
  background: rgba(6, 13, 27, 0.94);
  border: 1px solid rgba(85,201,255,0.30);
  box-shadow: 0 0 16px rgba(85,201,255,0.14);
}

.controls.hidden {
  display: none;
}

.controls h2 {
  margin: 0 0 14px;
  color: #55c9ff;
  font-size: 24px;
}

button, input, textarea, select {
  width: 100%;
  margin-bottom: 10px;
  padding: 10px 12px;
  border-radius: 10px;
  border: 1px solid rgba(85,201,255,0.35);
  font-family: "Open Sans", Arial, sans-serif;
  font-size: 16px;
}

button {
  cursor: pointer;
  background: rgba(85,201,255,0.13);
  color: #d8ecff;
  font-weight: 800;
}

button:hover {
  background: rgba(85,201,255,0.22);
}

textarea {
  min-height: 88px;
  resize: vertical;
}

.small-label {
  margin: 6px 0;
  color: #9ee8ff;
  font-size: 14px;
  font-weight: 800;
}

.mode-note {
  font-size: 13px;
  color: #aac8dd;
  line-height: 1.35;
}

@media (max-width: 900px) {
  .app {
    grid-template-columns: 1fr;
    padding: 34px;
  }

  .controls {
    width: 100%;
    max-width: 520px;
    margin: auto;
  }
}
</style>
</head>

<body>
<div class="frame"></div>

<div class="app">
  <main class="viewer">
    <div class="clock">
      <div id="date" class="date">LOADING DATE</div>
      <div id="time" class="time">LOADING TIME</div>
    </div>

    <section class="card">
      <div id="questionLabel" class="label">QUESTION 001</div>
      <div id="questionText" class="question">What organ pumps blood throughout the body?</div>
      <div id="answerBox" class="answer">Heart</div>
    </section>

    <div class="timer-wrap">
      <div id="timerBar" class="timer-bar"></div>
    </div>
  </main>

  <aside id="controls" class="controls">
    <h2>Arcane Controls</h2>

    <button onclick="toggleControls()">Viewer Mode / Controls (H)</button>
    <button onclick="nextQuestion()">Next Question (N)</button>
    <button onclick="showAnswer()">Show Answer (A)</button>
    <button onclick="toggleTimer()">Start / Pause Timer (Space)</button>

    <div class="small-label">Difficulty</div>
    <select id="difficultySelect" onchange="changeDifficulty()">
      <option value="easy">Easy Questions</option>
      <option value="hard">Hard Questions</option>
    </select>

    <div class="small-label">Question Seconds</div>
    <input id="questionSeconds" type="number" value="60" min="5" max="600" />

    <div class="small-label">Answer Seconds</div>
    <input id="answerSeconds" type="number" value="30" min="5" max="600" />
<div class="small-label">Question Size</div>

<input
  id="fontSizeSlider"
  type="range"
  min="24"
  max="80"
  value="52"
  oninput="changeQuestionSize(this.value)"
/>
    <div class="small-label">Add Question</div>
    <textarea id="newQuestion" placeholder="Type question here..."></textarea>
    <textarea id="newAnswer" placeholder="Type answer here..."></textarea>

    <button onclick="addQuestion()">Add Question To Current Difficulty</button>
    <button onclick="clearSavedQuestions()">Reset Saved Questions</button>

    <p class="mode-note">
      Hotkeys: H = hide controls, N = next, A = answer, Space = timer.
      Questions save in this browser automatically.
    </p>
  </aside>
</div>

<script>
const defaultBanks = {
  easy: [
    { q: "What organ pumps blood throughout the body?", a: "Heart" },
    { q: "Which organelle produces most ATP?", a: "Mitochondria" },
    { q: "What molecule carries genetic information?", a: "DNA" }
  ],
  hard: [
    { q: "A patient has proximal muscle weakness, hypertension, and hypokalemia. What endocrine disorder should be considered?", a: "Hyperaldosteronism or Cushing syndrome, depending on the full clinical picture." },
    { q: "Which nephron transporter is blocked by loop diuretics?", a: "Na⁺/K⁺/2Cl⁻ cotransporter in the thick ascending limb." },
    { q: "A child has recurrent infections, absent thymic shadow, hypocalcemia, and conotruncal defects. What deletion is likely?", a: "22q11 deletion, DiGeorge syndrome." }
  ]
};

let questionBanks = loadBanks();
let difficulty = "easy";
let currentIndex = 0;
let timer = null;
let total = 60;
let remaining = 60;

function loadBanks() {
  const saved = localStorage.getItem("sleepyQuizBanks");
  if (saved) {
    try {
      return JSON.parse(saved);
    } catch {
      return structuredClone(defaultBanks);
    }
  }
  return structuredClone(defaultBanks);
}

function saveBanks() {
  localStorage.setItem("sleepyQuizBanks", JSON.stringify(questionBanks));
}

function updateClock() {
  const now = new Date();

  document.getElementById("date").textContent =
    now.toLocaleDateString("en-US", {
      weekday: "short",
      month: "short",
      day: "numeric",
      year: "numeric"
    }).toUpperCase();

  document.getElementById("time").textContent =
    now.toLocaleTimeString("en-US", {
      hour: "numeric",
      minute: "2-digit",
      second: "2-digit",
      hour12: true
    });
}

function currentQuestions() {
  return questionBanks[difficulty];
}

function renderQuestion() {
  const bank = currentQuestions();

  if (!bank.length) {
    document.getElementById("questionLabel").textContent = "NO QUESTIONS";
    document.getElementById("questionText").textContent = "Add a question using the control panel.";
    document.getElementById("answerBox").style.display = "none";
    return;
  }

  const item = bank[currentIndex];

  document.getElementById("questionLabel").textContent =
    difficulty.toUpperCase() + " QUESTION " + String(currentIndex + 1).padStart(3, "0");

  document.getElementById("questionText").textContent = item.q;
  document.getElementById("answerBox").textContent = item.a;
  document.getElementById("answerBox").style.display = "none";

  resetTimer(Number(document.getElementById("questionSeconds").value || 60));
}

function nextQuestion() {
  const bank = currentQuestions();
  if (!bank.length) return;

  currentIndex = (currentIndex + 1) % bank.length;
  renderQuestion();
}

function showAnswer() {
  document.getElementById("answerBox").style.display = "block";
  resetTimer(Number(document.getElementById("answerSeconds").value || 30));
}

function changeDifficulty() {
  difficulty = document.getElementById("difficultySelect").value;
  currentIndex = 0;
  renderQuestion();
}

function addQuestion() {
  const q = document.getElementById("newQuestion").value.trim();
  const a = document.getElementById("newAnswer").value.trim();

  if (!q || !a) return;

  questionBanks[difficulty].push({ q, a });
  saveBanks();

  document.getElementById("newQuestion").value = "";
  document.getElementById("newAnswer").value = "";

  currentIndex = questionBanks[difficulty].length - 1;
  renderQuestion();
}

function clearSavedQuestions() {
  localStorage.removeItem("sleepyQuizBanks");
  questionBanks = structuredClone(defaultBanks);
  currentIndex = 0;
  renderQuestion();
}

function resetTimer(seconds) {
  clearInterval(timer);
  timer = null;
  total = Math.max(1, seconds);
  remaining = total;
  updateTimerBar();
}

function updateTimerBar() {
  const percent = Math.max(0, remaining / total) * 100;
  document.getElementById("timerBar").style.width = percent + "%";
}

function toggleTimer() {
  if (timer) {
    clearInterval(timer);
    timer = null;
    return;
  }

  timer = setInterval(() => {
    remaining--;
    updateTimerBar();

    if (remaining <= 0) {
      clearInterval(timer);
      timer = null;
      showAnswer();
    }
  }, 1000);
}
function changeQuestionSize(size) {
  document.getElementById("questionText").style.fontSize = size + "px";
}
function toggleControls() {
  document.getElementById("controls").classList.toggle("hidden");
}

document.addEventListener("keydown", (event) => {
  if (event.target.tagName === "TEXTAREA" || event.target.tagName === "INPUT") return;

  const key = event.key.toLowerCase();

  if (key === "h") toggleControls();
  if (key === "n") nextQuestion();
  if (key === "a") showAnswer();

  if (event.code === "Space") {
    event.preventDefault();
    toggleTimer();
  }
});

updateClock();
setInterval(updateClock, 1000);
renderQuestion();
</script>
</body>
</html>
