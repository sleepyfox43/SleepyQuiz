<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Arcane Study Terminal</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@400;600;700;800&display=swap" rel="stylesheet">

<style>
:root{
--bg:#050914;
--panel:rgba(8,16,32,.92);
--blue:#55c9ff;
--blueSoft:rgba(85,201,255,.25);
--text:#d8ecff;
}

*{box-sizing:border-box;}

body{
margin:0;
overflow:hidden;
font-family:"Open Sans",sans-serif;
background:
radial-gradient(circle at center, rgba(40,100,255,.15), transparent 40%),
linear-gradient(135deg,#02040a,#08111f,#02040a);
color:var(--text);
height:100vh;
}

body:before{
content:"";
position:fixed;
inset:0;
background-image:
radial-gradient(circle, rgba(120,210,255,.18) 1px, transparent 1px);
background-size:90px 90px;
opacity:.4;
animation:drift 25s linear infinite;
pointer-events:none;
}

@keyframes drift{
from{transform:translateY(0);}
to{transform:translateY(90px);}
}

.frame{
position:fixed;
inset:25px;
border:2px solid var(--blueSoft);
border-radius:18px;
box-shadow:0 0 15px rgba(85,201,255,.2), inset 0 0 20px rgba(85,201,255,.08);
pointer-events:none;
}

.container{
display:grid;
grid-template-columns:1fr 340px;
gap:30px;
height:100vh;
padding:50px;
}

.main{
display:flex;
flex-direction:column;
justify-content:center;
gap:25px;
}

.clock{
text-align:center;
text-shadow:0 0 10px rgba(85,201,255,.25);
}

.date{
font-size:22px;
letter-spacing:2px;
font-weight:700;
}

.time{
font-size:60px;
font-weight:800;
margin-top:5px;
}

.questionCard{
padding:40px;
border-radius:20px;
background:rgba(5,10,22,.85);
border:1px solid rgba(85,201,255,.3);
box-shadow:0 0 20px rgba(85,201,255,.12);
}

.label{
color:var(--blue);
font-weight:800;
letter-spacing:2px;
margin-bottom:20px;
font-size:20px;
text-shadow:0 0 8px rgba(85,201,255,.2);
}

.question{
font-size:52px;
line-height:1.4;
font-weight:700;
}

.answer{
display:none;
margin-top:25px;
padding:20px;
border-left:4px solid #8effb5;
background:rgba(20,80,40,.2);
border-radius:12px;
font-size:32px;
font-weight:700;
}

.timerWrap{
height:16px;
border-radius:999px;
overflow:hidden;
background:#07101d;
border:1px solid rgba(85,201,255,.25);
}

.timer{
height:100%;
width:100%;
background:linear-gradient(90deg, rgba(85,201,255,.4), rgba(85,201,255,1));
box-shadow:0 0 15px rgba(85,201,255,.4);
transition:width .3s linear;
}

.panel{
background:var(--panel);
border:1px solid rgba(85,201,255,.25);
border-radius:18px;
padding:20px;
align-self:center;
}

.panel.hidden{
display:none;
}

.title{
color:var(--blue);
font-weight:800;
font-size:24px;
margin-bottom:10px;
}

button,input,textarea,select{
width:100%;
margin-bottom:10px;
padding:10px;
border-radius:10px;
border:1px solid rgba(85,201,255,.25);
font-family:"Open Sans",sans-serif;
font-size:16px;
}

button{
background:rgba(85,201,255,.12);
color:var(--text);
font-weight:700;
cursor:pointer;
}

textarea{
min-height:90px;
}

.small{
font-size:14px;
color:#9bdfff;
font-weight:700;
margin:8px 0;
}

</style>
</head>
<body>

<div class="frame"></div>

<div class="container">

<div class="main">

<div class="clock">
<div class="date" id="date"></div>
<div class="time" id="time"></div>
</div>

<div class="questionCard">
<div class="label" id="qLabel">QUESTION 001</div>
<div class="question" id="question">What organ pumps blood throughout the body?</div>
<div class="answer" id="answer">Heart</div>
</div>

<div class="timerWrap">
<div class="timer" id="timer"></div>
</div>

</div>

<div class="panel" id="panel">
<div class="title">Arcane Controls</div>

<button onclick="togglePanel()">Hide Controls (H)</button>
<button onclick="nextQuestion()">Next Question (N)</button>
<button onclick="showAnswer()">Show Answer (A)</button>
<button onclick="toggleTimer()">Start / Pause (Space)</button>

<div class="small">Difficulty</div>
<select id="difficulty" onchange="changeDifficulty()">
<option value="easy">Easy</option>
<option value="hard">Hard</option>
</select>

<div class="small">Question Seconds</div>
<input id="qSeconds" type="number" value="60">

<div class="small">Answer Seconds</div>
<input id="aSeconds" type="number" value="30">

<div class="small">Add Question</div>
<textarea id="newQ" placeholder="Question..."></textarea>
<textarea id="newA" placeholder="Answer..."></textarea>

<button onclick="addQuestion()">Add Question</button>

</div>

</div>

<script>

const banks = {
easy:[
{q:"What organ pumps blood throughout the body?",a:"Heart"},
{q:"What organelle creates ATP?",a:"Mitochondria"}
],
hard:[
{q:"A patient has proximal muscle weakness and hypokalemia. What endocrine disorder may be present?",a:"Hyperaldosteronism or Cushing syndrome"},
{q:"Which nephron transporter is blocked by loop diuretics?",a:"Na/K/2Cl transporter"}
]
};

let difficulty = "easy";
let current = 0;
let questions = banks[difficulty];

let timer = null;
let total = 60;
let remaining = 60;

function updateClock(){
const now = new Date();

document.getElementById("date").textContent =
now.toLocaleDateString("en-US",{
weekday:"long",
month:"long",
day:"numeric",
year:"numeric"
}).toUpperCase();

document.getElementById("time").textContent =
now.toLocaleTimeString("en-US",{
hour:"numeric",
minute:"2-digit",
second:"2-digit",
hour12:true
});
}

setInterval(updateClock,1000);
updateClock();

function render(){
const item = questions[current];

document.getElementById("qLabel").textContent =
`QUESTION ${String(current+1).padStart(3,"0")}`;

document.getElementById("question").textContent = item.q;
document.getElementById("answer").textContent = item.a;
document.getElementById("answer").style.display = "none";

resetTimer(Number(document.getElementById("qSeconds").value));
}

function nextQuestion(){
current = (current + 1) % questions.length;
render();
}

function showAnswer(){
document.getElementById("answer").style.display = "block";
}

function changeDifficulty(){
difficulty = document.getElementById("difficulty").value;
questions = banks[difficulty];
current = 0;
render();
}

function addQuestion(){
const q = document.getElementById("newQ").value.trim();
const a = document.getElementById("newA").value.trim();

if(!q || !a) return;

banks[difficulty].push({q,a});
questions = banks[difficulty];

document.getElementById("newQ").value = "";
document.getElementById("newA").value = "";

current = questions.length - 1;
render();
}

function resetTimer(seconds){
clearInterval(timer);
total = seconds;
remaining = seconds;
updateBar();
}

function updateBar(){
const percent = (remaining/total)*100;
document.getElementById("timer").style.width = percent + "%";
}

function toggleTimer(){

if(timer){
clearInterval(timer);
timer = null;
return;
}

timer = setInterval(()=>{
remaining--;
updateBar();

if(remaining <= 0){
clearInterval(timer);
timer = null;
showAnswer();
}
},1000);

}

function togglePanel(){
document.getElementById("panel").classList.toggle("hidden");
}

document.addEventListener("keydown",(e)=>{
if(e.target.tagName === "TEXTAREA" || e.target.tagName === "INPUT") return;

if(e.key.toLowerCase() === "h") togglePanel();
if(e.key.toLowerCase() === "n") nextQuestion();
if(e.key.toLowerCase() === "a") showAnswer();

if(e.code === "Space"){
e.preventDefault();
toggleTimer();
}
});

render();

</script>

</body>
</html>
